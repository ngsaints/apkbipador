# Configurações do Agente WMS Rocket

# URL da API no Base44 que o agente vai monitorar
API_URL=https://wmsrocket.base44.app/api/orders/finalized

# Intervalo de verificação em milissegundos (ex: 30000 = 30 segundos)
POLLING_INTERVAL=30000

# Nome exato da impressora no Windows
PRINTER_NAME=Zebra ZD220

# URL do Aplicativo Web que o Electron vai carregar
APP_URL=https://wmsrocket.base44.app
